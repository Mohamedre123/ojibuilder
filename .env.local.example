# انسخ هذا الملف إلى .env.local وضع مفتاحك
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# (اختياري) كلمة سر لقفل استخدام المنصة
# APP_ACCESS_PASSWORD=

# (إنتاج/Vercel) للنشر وحفظ المشاريع بشكل دائم عبر Vercel Blob.
# أنشئ Blob Store من لوحة Vercel (Storage) ويُضاف هذا المتغير تلقائيًا.
# بدونه: يُحفظ محليًا على الملفات (للتطوير فقط).
# BLOB_READ_WRITE_TOKEN=

# (اختياري) لتفعيل النشر على نطاقات فرعية حقيقية: <id>.example.com
# يتطلب ربط نطاق wildcard (*.example.com) في Vercel.
# APP_DOMAIN=

# Vercel domains (custom domain feature)
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
# MAIN_APP_HOST=
